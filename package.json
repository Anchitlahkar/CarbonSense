{
  "name": "carbonsense-workspace",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "CarbonSense X — Carbon Footprint Awareness and Applied AI Behavioral Optimization Platform",
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run dev",
    "install:all": "npm install",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently -n \"frontend,backend\" -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:packages": "npm run build --workspace=@carbonsense/core --workspace=@carbonsense/shared-types --workspace=@carbonsense/knowledge-base --workspace=@carbonsense/ai-orchestration --workspace=@carbonsense/behavior-intelligence-engine --workspace=@carbonsense/carbon-dna-engine --workspace=@carbonsense/carbon-science-engine --workspace=@carbonsense/forecast-engine --workspace=@carbonsense/optimization-engine --workspace=@carbonsense/planet-twin-engine --workspace=@carbonsense/receipt-intelligence-engine --if-present",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build": "npm run build:packages && npm run build:backend && npm run build:frontend",
    "vercel-build": "npm run build && rm -rf public && mv frontend/dist public",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1"
  }
}
